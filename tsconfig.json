{
  "compilerOptions": {
    "strict": true, // default in ts6, can be removed after upgrade
    "module": "esnext", // default in ts6, can be removed after upgrade
    "moduleResolution": "bundler", // default in ts6, can be removed after upgrade
    "target": "esnext", // default in ts6, can be removed after upgrade
    "rootDir": ".", // default in ts6, can be removed after upgrade
    "noUncheckedSideEffectImports": true, // default in ts6, can be removed after upgrade
    "libReplacement": false, // default in ts6, can be removed after upgrade
    "types": ["node"],
    "lib": ["ESNext"],
    "paths": {
      "~/*": ["./src/*"]
    },
  },
  "include": [
    "**/*.ts",
  ],
  "exclude": ["node_modules", "dist"]
}
